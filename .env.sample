# DriveLM Qwen VQA — sample environment file.
#
# Copy to .env (which is gitignored) and edit. python-dotenv autoloads it at
# script start; alternatively `export $(grep -v '^#' .env | xargs)` works in
# any shell. All values shown below are the in-code defaults — uncomment the
# ones you want to override.
#
# Naming conventions:
#   * Python config (src/config.py): DRIVELM_<SECTION>__<FIELD>  (two underscores)
#   * vLLM launcher (src/vllm_launcher.py): DRIVELM_VLLM_<FIELD>  (single underscore)
#   These two schemes are intentionally separate because the launcher passes
#   directly to the `vllm serve` CLI and its knobs don't map to the four-section
#   data/model/train/eval config.


# =============================================================================
# Data (DataCfg)
# =============================================================================
# DRIVELM_DATA__NUSCENES_DIR=data/nuscenes
# DRIVELM_DATA__DRIVELM_JSON=data/drivelm/v1_1_train_nus.json
# DRIVELM_DATA__CAMERA_MODE=front-arc      # front | front-arc | all | mosaic
# DRIVELM_DATA__IMAGE_LONG_EDGE=448


# =============================================================================
# Model (ModelCfg) — for training and eval client
# =============================================================================
# DRIVELM_MODEL__MODEL_ID=Qwen/Qwen3.5-0.8B
# DRIVELM_MODEL__LORA_MODEL_ID=drivelm-lora     # served name for the adapter
# DRIVELM_MODEL__QUANTIZATION=auto              # auto | none | 4bit | 8bit
# DRIVELM_MODEL__DEVICE=auto
# DRIVELM_MODEL__DTYPE=auto
# DRIVELM_MODEL__MAX_NEW_TOKENS=64


# =============================================================================
# Training (TrainCfg) — consumed by src/train/finetune.py
# =============================================================================
# DRIVELM_TRAIN__NUM_SAMPLES=1024
# DRIVELM_TRAIN__EPOCHS=1
# DRIVELM_TRAIN__LR=2e-4
# DRIVELM_TRAIN__LORA_R=8
# DRIVELM_TRAIN__LORA_ALPHA=16
# DRIVELM_TRAIN__GRADIENT_ACCUMULATION_STEPS=2
# DRIVELM_TRAIN__CHECKPOINT_EVERY=200
# DRIVELM_TRAIN__OUTPUT_DIR=models/qwen-lora
# DRIVELM_TRAIN__SAMPLING=natural               # natural | stratified | proportional
# DRIVELM_TRAIN__STRATIFIED=false               # legacy alias for sampling=stratified
# DRIVELM_TRAIN__STRATIFIED_SEED=42


# =============================================================================
# Eval (EvalCfg) — consumed by src/eval/eval.py
# =============================================================================
# DRIVELM_EVAL__BASE_URL=http://127.0.0.1:8001/v1
# DRIVELM_EVAL__API_KEY=local
# DRIVELM_EVAL__NUM_SAMPLES=0                   # 0 = all locally usable
# DRIVELM_EVAL__TEMPERATURE=0.0
# DRIVELM_EVAL__CONCURRENCY=4
# DRIVELM_EVAL__TIMEOUT=180
# DRIVELM_EVAL__MAX_RETRIES=3
# DRIVELM_EVAL__RUN_BASE=true
# DRIVELM_EVAL__RUN_LORA=true
# DRIVELM_EVAL__OUTPUT_BASE_JSON=artifacts/baseline_front_arc_full.json
# DRIVELM_EVAL__OUTPUT_LORA_JSON=artifacts/finetuned_front_arc_full.json


# =============================================================================
# vLLM launcher — consumed by src/vllm_launcher.py only
# =============================================================================
# DRIVELM_MODEL_ID=Qwen/Qwen3.5-0.8B            # also read by Qwen helpers in src/qwen.py
# DRIVELM_VLLM_HOST=0.0.0.0
# DRIVELM_VLLM_PORT=8001
# DRIVELM_VLLM_DTYPE=float16
# DRIVELM_VLLM_MAX_MODEL_LEN=1024
# DRIVELM_VLLM_GPU_MEMORY_UTILIZATION=0.60      # raise on bigger GPUs
# DRIVELM_VLLM_MM_PROCESSOR_CACHE_GB=1
# DRIVELM_VLLM_MAX_NUM_SEQS=4
# DRIVELM_VLLM_MAX_NUM_BATCHED_TOKENS=2048
# DRIVELM_VLLM_ATTENTION_BACKEND=TRITON_ATTN    # use FLASHINFER on Ampere+
# DRIVELM_VLLM_IMAGE_COUNT=6
# DRIVELM_VLLM_IMAGE_WIDTH=336
# DRIVELM_VLLM_IMAGE_HEIGHT=336
# DRIVELM_VLLM_ENFORCE_EAGER=1                  # 0 on bigger GPUs to enable CUDA graphs
# DRIVELM_VLLM_SKIP_MM_PROFILING=1
# DRIVELM_VLLM_MAX_LORA_RANK=8
# DRIVELM_LORA_PATH=models/qwen-lora            # auto-attached if adapter_config.json exists
# DRIVELM_LORA_NAME=drivelm-lora
# DRIVELM_ENABLE_LORA=                          # unset = auto-detect; "1" forces on


# =============================================================================
# Misc
# =============================================================================
# HF_TOKEN=                                     # only if pulling gated models/datasets
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True   # set in shell, not in .env
